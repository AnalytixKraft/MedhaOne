{
  "name": "medhaone",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "stack:up": "bash scripts/dev-up.sh",
    "stack:down": "bash scripts/dev-down.sh",
    "stack:restart": "bash scripts/dev-restart.sh",
    "ai:test": "ts-node apps/web/e2e/ai/runner.ts",
    "dev": "concurrently -n web,api -c cyan,green \"pnpm --config.engine-strict=false --filter web dev\" \"pnpm --config.engine-strict=false --filter api dev\"",
    "rbac:db:up": "docker compose up -d --no-build --remove-orphans rbac-postgres",
    "rbac:db:down": "docker compose stop rbac-postgres",
    "rbac:dev": "pnpm --config.engine-strict=false --filter rbac-api dev",
    "rbac:build": "pnpm --filter rbac-api build",
    "rbac:prisma:generate": "pnpm --filter rbac-api prisma:generate",
    "rbac:prisma:migrate": "pnpm --filter rbac-api prisma:migrate",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "format": "pnpm --filter web format",
    "seed": "pnpm --filter api seed",
    "e2e": "pnpm --filter web e2e",
    "e2e:ui": "pnpm --filter web e2e:ui",
    "e2e:debug": "pnpm --filter web e2e:debug",
    "guided:test": "pnpm --filter web guided:test",
    "guided:test:po-grn": "pnpm --filter web guided:test:po-grn"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
