# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:1729
NEXT_PUBLIC_API_BASE_URL=http://localhost:1730

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:55432/medhaone_rbac
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:1729
DEFAULT_ADMIN_EMAIL=admin@medhaone.app
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
# Set to true for deterministic AI workflow runs that rely on reset/seed helpers.
ENABLE_TEST_ENDPOINTS=false

# AI testing engine
AI_TEST_ENABLED=false
AI_TEST_BASE_URL=http://localhost:1729
AI_TEST_MODE=acceptance
AI_TEST_WORKFLOW=login
AI_TEST_ORG_MAX_USERS=10
AI_TEST_PERSIST_DATA=false
AI_TEST_HEADLESS=true
AI_TEST_MAX_STEPS=40
AI_TEST_MODEL=gpt-4o-mini
AI_TEST_TIMEOUT_MS=60000
OPENAI_API_KEY=

# Multi-tenant RBAC service (Express + PostgreSQL)
# Dockerized PostgreSQL for RBAC
RBAC_POSTGRES_HOST=127.0.0.1
RBAC_POSTGRES_PORT=55432
RBAC_POSTGRES_DB=medhaone_rbac
RBAC_POSTGRES_USER=postgres
RBAC_POSTGRES_PASSWORD=postgres

# Multi-tenant RBAC service (Express + PostgreSQL)
RBAC_PORT=1740
RBAC_JWT_SECRET=replace-me-with-a-long-random-secret
RBAC_JWT_EXPIRES_IN=8h
RBAC_CORS_ORIGIN=http://localhost:1729
RBAC_SUPER_ADMIN_EMAIL=superadmin@medhaone.app
RBAC_SUPER_ADMIN_PASSWORD=ChangeThisImmediately!
NEXT_PUBLIC_RBAC_API_BASE_URL=http://localhost:1740
